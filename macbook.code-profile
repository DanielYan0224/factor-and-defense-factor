{"name":"macbook","settings":"{\"settings\":\"{\\n    \\\"python.languageServer\\\": \\\"Pylance\\\",\\n    \\\"jupyter.interactiveWindow.creationMode\\\": \\\"perFile\\\",\\n    \\\"git.autofetch\\\": true,\\n    \\\"search.useGlobalIgnoreFiles\\\": true,\\n    \\\"interactiveWindow.alwaysScrollOnNewCell\\\": false,\\n    \\\"interactiveWindow.promptToSaveOnClose\\\": true,\\n    \\\"jupyter.interactiveWindow.textEditor.executeSelection\\\": true,\\n    \\\"json.schemaDownload.enable\\\": true,\\n    \\\"terminal.integrated.inheritEnv\\\": false,\\n    \\\"git.confirmSync\\\": false,\\n    \\\"editor.showFoldingControls\\\": \\\"always\\\",\\n    \\\"notebook.showFoldingControls\\\": \\\"always\\\",\\n    \\\"editor.fontSize\\\": 14,\\n    \\\"editor.mouseWheelZoom\\\": true,\\n    \\\"editor.foldingStrategy\\\": \\\"indentation\\\",\\n    \\\"workbench.colorTheme\\\": \\\"Night Owl\\\",\\n    \\\"workbench.iconTheme\\\": \\\"material-icon-theme\\\",\\n    \\\"workbench.colorCustomizations\\\": {\\n        // 設定編輯器背景為極深的藍黑色 (接近 Antigravity 的深邃感)\\n        \\\"editor.background\\\": \\\"#000a11\\\",\\n        // 順便把側邊欄也變深，才不會覺得只有中間是黑的\\n        \\\"sideBar.background\\\": \\\"#000a11\\\",\\n        \\\"activityBar.background\\\": \\\"#000a11\\\"\\n    },\\n    // ↓↓↓ (舊) 這裡控制文字顏色 (斜體、註解) ↓↓↓\\n    \\\"editor.tokenColorCustomizations\\\": {\\n        \\\"textMateRules\\\": [\\n            {\\n                \\\"scope\\\": [\\n                    \\\"comment\\\",\\n                    \\\"comment.block\\\",\\n                    \\\"comment.line\\\",\\n                    \\\"punctuation.definition.comment\\\"\\n                ],\\n                \\\"settings\\\": {\\n                    \\\"foreground\\\": \\\"#7fdbca\\\",\\n                    \\\"fontStyle\\\": \\\"italic\\\"\\n                }\\n            },\\n            {\\n                \\\"scope\\\": [\\n                    \\\"keyword\\\",\\n                    \\\"storage.type\\\",\\n                